# Supabase Postgres (use the transaction pooler connection string)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Qdrant Cloud
QDRANT_URL=https://xxx.cloud.qdrant.io:6333
QDRANT_API_KEY=

# LLM providers
GROQ_API_KEY=
GEMINI_API_KEY=

# Admin token for tenant management endpoints
ADMIN_TOKEN=changeme-strong-random-token

# Embedding model (local, downloaded on first run)
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# LLM model names
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash

# Rate limiting defaults (per tenant, can be overridden in DB)
DEFAULT_QUERY_RPM=60
DEFAULT_INGEST_RPM=300

# Worker
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_RETRIES=3

# App
LOG_LEVEL=INFO

# Optional Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Empty disables.
GA_MEASUREMENT_ID=

# Public demo tenant API key surfaced to the login screen "Try demo" button.
# Empty hides the button.
DEMO_API_KEY=
