        {
          "name": "POST /v1/documents — idempotent re-upload",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Re-upload the SAME file you used in 'upload (text)'. The id returned should match — content_hash deduplicates."
                }
              ]
            },
            "url": { "raw": "{{base_url}}/v1/documents", "host": ["{{base_url}}"], "path": ["v1", "documents"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const prev = pm.collectionVariables.get('document_id');",
                  "pm.test('idempotent: returns the same document id', () => pm.expect(j.id).to.eql(prev));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/documents/:id — status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/documents/{{document_id}}",
