{
  "info": {
    "_postman_id": "8e5b1e9d-7a0c-4c2e-9f4a-2c1d6f9b1a01",
    "name": "RAG Platform",
    "description": "End-to-end test collection for the multi-tenant RAG platform.\n\n**Setup**\n1. Import this collection into Postman.\n2. The collection variables `base_url`, `api_key`, and `admin_token` are pre-set to the hosted demo. Override them in the collection's Variables tab to point at your own deployment or a local server.\n3. For upload requests, click the request → Body → select a file from your machine.\n\n**Workflow**\n- Run **Documents → Upload (text)** first; the test script captures the returned `id` into the `document_id` collection variable.\n- Then run **Documents → Get document status** until it returns `\"status\": \"indexed\"`.\n- Then run any **Query** request.\n\nNegative tests intentionally produce 4xx responses; the test scripts assert the right code.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{api_key}}", "type": "string" }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://msmandy94-rag-platform.hf.space",
      "type": "string",
      "description": "Hosted demo. Use http://localhost:7860 for local."
    },
    {
      "key": "api_key",
      "value": "rag_su0VbkNg1eGg1iW15wPokMSxSFJkIV8SUwmLLLnBjzQ",
      "type": "string",
      "description": "Demo tenant API key."
    },
    {
      "key": "admin_token",
      "value": "admin_eS9fH2PqLn7vXcK4mD3RtBzWhN6yJ8aQ",
