                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "console.log('status:', j.status, 'chunks:', j.chunk_count);",
                  "pm.test('status is one of pending/processing/indexed/failed', () =>",
