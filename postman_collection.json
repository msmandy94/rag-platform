    {
      "name": "Query",
      "item": [
        {
          "name": "POST /v1/query — basic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is the data retention period for customer records?\",\n  \"top_k\": 5\n}"
            },
            "url": { "raw": "{{base_url}}/v1/query", "host": ["{{base_url}}"], "path": ["v1", "query"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('answer present', () => pm.expect(j.answer).to.be.a('string').and.not.empty);",
                  "pm.test('citations present', () => pm.expect(j.citations).to.be.an('array'));",
                  "pm.test('provider populated', () => pm.expect(['groq','gemini','none']).to.include(j.provider));",
                  "console.log('provider:', j.provider, 'latency_ms:', j.latency_ms);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/query — multi-doc synthesis",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Summarize the approved AI providers and the incident response SLAs.\",\n  \"top_k\": 8\n}"
            },
            "url": { "raw": "{{base_url}}/v1/query", "host": ["{{base_url}}"], "path": ["v1", "query"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('uses citations like [n]', () => pm.expect(j.answer).to.match(/\\[\\d+/));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/query — restricted to one document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What does this document say?\",\n  \"top_k\": 5,\n  \"document_ids\": [\"{{document_id}}\"]\n}"
            },
            "url": { "raw": "{{base_url}}/v1/query", "host": ["{{base_url}}"], "path": ["v1", "query"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const expected = pm.collectionVariables.get('document_id');",
                  "pm.test('all citations come from the requested document', () => {",
                  "  if (j.citations && j.citations.length > 0) {",
                  "    j.citations.forEach(c => pm.expect(c.document_id).to.eql(expected));",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
